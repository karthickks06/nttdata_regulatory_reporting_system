<?xml version="1.0" encoding="utf-8"?>
<!--

**********************************************************************************************
*                                                                 
*    Schema for: Data Item - PSD008 Product Sales Data - Credit Agreement Sales                 
*                                                                 
*    Version:    	1.1
*    Date:       	10 March 2025
*                                                          
*    History:    	Version 1.1 Amended the following XML element names:
*					- 'LendngType' to 'LendingType'
